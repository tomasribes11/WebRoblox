[
  {
    "key": "ctrl+`",
    "command": "workbench.action.terminal.toggle",
    "when": "!terminalFocus"
  },
  {
    "key": "ctrl+shift+`",
    "command": "workbench.action.terminal.split",
    "when": "terminalFocus"
  },
  {
    "key": "ctrl+1",
    "command": "workbench.action.terminal.focusAtIndex",
    "args": 1
  },
  {
    "key": "ctrl+2",
    "command": "workbench.action.terminal.focusAtIndex",
    "args": 2
  },
  {
    "key": "ctrl+3",
    "command": "workbench.action.terminal.focusAtIndex",
    "args": 3
  },
  {
    "key": "ctrl+shift+d",
    "command": "workbench.action.tasks.runTask",
    "args": "Docker: Start Services"
  },
  {
    "key": "ctrl+shift+s",
    "command": "workbench.action.tasks.runTask",
    "args": "Docker: Stop Services"
  },
  {
    "key": "ctrl+shift+l",
    "command": "workbench.action.tasks.runTask",
    "args": "Docker: View Logs"
  },
  {
    "key": "ctrl+shift+m",
    "command": "workbench.action.tasks.runTask",
    "args": "Laravel: Run Migrations"
  },
  {
    "key": "ctrl+shift+t",
    "command": "workbench.action.tasks.runTask",
    "args": "Laravel: Run Tests"
  },
  {
    "key": "ctrl+shift+f",
    "command": "workbench.action.tasks.runTask",
    "args": "Laravel: Fix Code Style"
  },
  {
    "key": "ctrl+shift+b",
    "command": "workbench.action.tasks.runTask",
    "args": "Laravel: Backend Shell"
  }
]
