# ─── Laravel (also in backend/.env — keep these in sync) ──────────────────
# These are read by docker-compose.yml to pass into the php-fpm container.
# The actual Laravel .env is at backend/.env
APP_KEY=                        # Generated by: php artisan key:generate
APP_URL=http://localhost

# ─── Frontend ─────────────────────────────────────────────────────────────
# The React app reads this to know where the API is
VITE_API_URL=http://localhost/api/v1
